---
const { title, desc } = Astro.props;
---

<head>
  <link rel="icon" type="image/png" href="/m-abban.png" />
  <meta name="generator" content={Astro.generator} />

  <meta charset="utf8" />

  <title>{title}</title>
  <meta name="title" content={title} />
  <meta name="description" content={desc} />
</head>
